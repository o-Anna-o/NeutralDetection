<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:background="@android:color/black"
        android:padding="16dp"
        android:text="@string/no_face"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#80000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/fpsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FPS: 0.0"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/mouthRatioText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mouth Ratio: 0.00"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/eyeRatioText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Eye Ratio: 0.00"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/eyebrowRatioText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Eyebrow Ratio: 0.00"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/confidenceText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confidence: 0%"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <ProgressBar
            android:id="@+id/confidenceProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/neutral_green" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>